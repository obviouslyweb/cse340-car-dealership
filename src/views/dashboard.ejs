<%- include('partials/header') %>
<main>
    <div class="dashboard">
        <h2>Dashboard</h2>
        
        <p>Welcome back, <strong><%= user.name %></strong>! This is your <strong><%= user.roleName %> dashboard</strong> where you can interact with our services.</strong></p>  

        <% if (isAdmin) { %>
        <div class="card button-card red">
            <h2>Admin Actions</h2>
            <div class="action-list">
                <a href="/moderation/add_vehicle" class="btn">Add Vehicle</a>
                <a href="/moderation/categories" class="btn">Edit Vehicle Categories</a>
                <a href="/moderation/users" class="btn">Review Accounts</a>
                <a href="/moderation/activity-log" class="btn">View Database Log</a>
            </div>
        </div>
        <% } %>

        <% if (isEmployee) { %>
        <div class="card button-card yellow">
            <h2>Employee Actions</h2>
            <div class="action-list">
                <a href="/moderation/service" class="btn">View Service Requests</a>
                <a href="/moderation/contact" class="btn">View Contact Submissions</a>
                <a href="/moderation/reviews" class="btn">Moderate Submitted Reviews</a>
                <a href="/vehicles/" class="btn">Review/Edit Vehicles</a>
            </div>
        </div>
        <% } %>

        <div class="card dashboard-detail">
            <div class="side-view">
                <div class="side-view-left">
                    <h2>My Service Requests</h2>
                </div>
                <div class="side-view-right">
                    <a href="/service-request" class="btn">Submit Service Request</a>
                </div>
            </div>

            <% if (myServiceRequests && myServiceRequests.length > 0) { %>
                <ul class="my-requests-list">
                    <% myServiceRequests.forEach(function(sr) { %>
                        <li class="dashboard-request-item" id="request-<%= sr.id %>">
                            <div class="request-display">
                                <div class="request-display-header">
                                    <span class="request-service-type"><%= sr.service_type %></span>
                                    <span class="request-vehicle-name"><%= sr.vehicle_name %></span>
                                    <span class="request-meta-date"><%= new Date(sr.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                    <span class="request-status request-status-<%= sr.status.replace(/\\s+/g, '-').toLowerCase() %>"><%= sr.status %></span>
                                </div>
                                <% if (sr.description) { %>
                                    <p class="request-body"><strong>Your Notes: </strong><%= sr.description %></p>
                                <% } %>
                                <% if (sr.status_facing_user) { %>
                                    <p class="request-body"><strong>Status Update: </strong><%= sr.status_facing_user %></p>
                                <% } %>
                                <div class="request-actions-display">
                                    <button type="button" class="btn" data-request-edit="<%= sr.id %>">Edit</button>
                                </div>
                            </div>
                            <form class="request-edit-form form-style hidden" method="POST" action="/dashboard/service-requests/<%= sr.id %>/edit" data-request-id="<%= sr.id %>">
                                <div class="request-edit-header">
                                    <select name="service_type" class="request-edit-service-type" required>
                                        <% ['Oil Change','Tire Rotation','Brake Service','Battery Replacement','Filter Replacement','Multi-Point Inspection','Fluid Flush','Alignment','Other'].forEach(function(type) { %>
                                            <option value="<%= type %>" <%= sr.service_type === type ? 'selected' : '' %>><%= type %></option>
                                        <% }); %>
                                    </select>
                                    <input type="text" name="vehicle_name" class="request-edit-vehicle-name" maxlength="50" required value="<%= sr.vehicle_name %>">
                                    <span class="request-meta-date"><%= new Date(sr.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                </div>
                                <textarea name="description" class="request-edit-body" rows="4" maxlength="2000" placeholder="Additional details (optional)"><%= sr.description || '' %></textarea>
                                <div class="request-edit-actions">
                                    <button type="submit" class="btn">Save Changes</button>
                                    <button type="button" class="btn lowlight request-edit-cancel" data-request-id="<%= sr.id %>">Cancel Edits</button>
                                </div>
                            </form>
                        </li>
                    <% }); %>
                </ul>
                <script>
                    (function () {
                        document.querySelectorAll('[data-request-edit]').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                var id = this.getAttribute('data-request-edit');
                                var li = document.getElementById('request-' + id);
                                if (!li) return;
                                li.querySelector('.request-display').classList.add('hidden');
                                li.querySelector('.request-edit-form').classList.remove('hidden');
                            });
                        });
                        document.querySelectorAll('.request-edit-cancel').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                var id = this.getAttribute('data-request-id');
                                var li = document.getElementById('request-' + id);
                                if (!li) return;
                                li.querySelector('.request-display').classList.remove('hidden');
                                li.querySelector('.request-edit-form').classList.add('hidden');
                            });
                        });
                    })();
                </script>
            <% } else { %>
                <p class="my-requests-empty">You don't have any service requests yet.</p>
            <% } %>
        </div>

        <div class="card my-reviews-detail">
            <h2>My Reviews</h2>
            <% if (myReviews && myReviews.length > 0) { %>
                <ul class="my-reviews-list">

                    <% myReviews.forEach(review => { %>
                        <li class="dashboard-review-item" id="review-<%= review.id %>">
                            <div class="review-display">
                                <div class="review-display-header">
                                    <a href="/vehicles/<%= review.vehicle_id %>"><%= review.vehicle_year %> <%= review.vehicle_make %> <%= review.vehicle_model %></a>
                                    <span aria-label="Rating: <%= review.rating %> out of 5">
                                        <% for (let i = 0; i < 5; i++) { %><%= i < review.rating ? '★' : '☆' %><% } %>
                                    </span>
                                    <span class="review-meta-date"><%= new Date(review.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                    <% if (!review.is_visible) { %>
                                        <span class="review-pending">Pending review</span>
                                    <% } %>
                                </div>
                                <p class="review-body"><%= review.body %></p>
                                <div class="review-actions-display">
                                    <button type="button" class="btn" data-review-edit="<%= review.id %>">Edit</button>
                                    <form method="POST" action="/dashboard/reviews/<%= review.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                        <button type="submit" class="btn lowlight">Delete review</button>
                                    </form>
                                </div>
                            </div>
                            <form class="review-edit-form form-style hidden" method="POST" action="/dashboard/reviews/<%= review.id %>/edit" data-review-id="<%= review.id %>">
                                <div class="review-edit-header">
                                    <a href="/vehicles/<%= review.vehicle_id %>"><%= review.vehicle_year %> <%= review.vehicle_make %> <%= review.vehicle_model %></a>
                                    <select id="edit-rating-<%= review.id %>" name="rating" class="review-edit-rating" required>
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <option value="<%= i %>" <%= review.rating === i ? 'selected' : '' %>><%= i %> star<%= i !== 1 ? 's' : '' %></option>
                                        <% } %>
                                    </select>
                                    <span class="review-meta-date"><%= new Date(review.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                                </div>
                                <textarea id="edit-body-<%= review.id %>" name="body" class="review-edit-body" rows="6" minlength="10" maxlength="2000" required placeholder="Your review..."><%= review.body %></textarea>
                                <div class="review-edit-actions">
                                    <button type="submit" class="btn">Edit Review</button>
                                    <button type="button" class="btn lowlight review-edit-cancel" data-review-id="<%= review.id %>">Cancel Edits</button>
                                </div>
                            </form>
                        </li>
                    <% }); %>

                </ul>
                <script>
                    (function() {
                        document.querySelectorAll('[data-review-edit]').forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                var id = this.getAttribute('data-review-edit');
                                var li = document.getElementById('review-' + id);
                                if (!li) return;
                                li.querySelector('.review-display').classList.add('hidden');
                                li.querySelector('.review-edit-form').classList.remove('hidden');
                            });
                        });
                        document.querySelectorAll('.review-edit-cancel').forEach(function(btn) {
                            btn.addEventListener('click', function() {
                                var id = this.getAttribute('data-review-id');
                                var li = document.getElementById('review-' + id);
                                if (!li) return;
                                li.querySelector('.review-display').classList.remove('hidden');
                                li.querySelector('.review-edit-form').classList.add('hidden');
                            });
                        });
                    })();
                </script>
            <% } else { %>
                <p class="my-reviews-empty">You haven't submitted any reviews yet.</p>
            <% } %>
        </div>

        <div class="card">
            <h2>Your Account Information</h2>
            <div class="user-detail">
                <div>
                    <span class="label">Name:</span>
                    <span class="value"><%= user.name %></span>
                </div>
                <div>
                    <span class="label">Email:</span>
                    <span class="value"><%= user.email %></span>
                </div>
                <div>
                    <span class="label">Account created:</span>
                    <span class="value"><%= new Date(user.created_at).toLocaleDateString() %></span>
                </div>
            </div>
        </div>

        <div class="dashboard-actions">
            <a href="/logout" class="lowlight btn logout-button">Logout</a>
        </div>
        
    </div>
</main>
<%- include('partials/footer') %>