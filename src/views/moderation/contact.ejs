<%- include('../partials/header') %>
<main>
    <div class="dashboard">
        <h1>Contact Form Submissions</h1>
        <p><a href="/dashboard" class="btn lowlight">← Back to Dashboard</a></p>

        <% if (contactForms && contactForms.length > 0) { %>
            <ul class="moderation-contact-list">
                <% contactForms.forEach(form => { %>
                    <li class="card">
                        <div class="submission-meta">
                            <strong>Submitted:</strong>
                            <span><%= new Date(form.submitted).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                        </div>
                        <h3 class="response-subject"><%= form.subject %></h3>
                        <p class="response-message"><%= form.message %></p>
                        <div class="submission-actions">
                            <form method="POST" action="/moderation/contact/<%= form.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this submission? This cannot be undone.');">
                                <button type="submit" class="btn lowlight btn-danger">Delete</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="no-submissions">No contact form submissions yet.</p>
        <% } %>
    </div>
</main>
<%- include('../partials/footer') %>
