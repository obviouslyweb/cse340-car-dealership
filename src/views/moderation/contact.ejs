<%- include('../partials/header') %>
<main>
    <div class="dashboard">
        <h1>Contact Form Submissions</h1>
        <p><a href="/dashboard" class="btn lowlight">← Back to Dashboard</a></p>

        <% if (contactForms && contactForms.length > 0) { %>
            <ul class="moderation-contact-list" style="list-style: none; padding: 0;">
                <% contactForms.forEach(form => { %>
                    <li class="card" style="margin-bottom: 1rem;">
                        <div class="submission-meta" style="display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; margin-bottom: 0.5rem;">
                            <strong>Submitted:</strong>
                            <span><%= new Date(form.submitted).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                        </div>
                        <h3 class="response-subject" style="margin: 0.5rem 0; color: #2c5aa0;"><%= form.subject %></h3>
                        <p class="response-message" style="margin: 0.75rem 0; white-space: pre-wrap;"><%= form.message %></p>
                        <div class="submission-actions" style="display: flex; gap: 0.5rem;">
                            <form method="POST" action="/moderation/contact/<%= form.id %>/delete" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this submission? This cannot be undone.');">
                                <button type="submit" class="btn lowlight" style="border-color: #dc3545; color: #dc3545;">Delete</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="no-submissions">No contact form submissions yet.</p>
        <% } %>
    </div>
</main>
<%- include('../partials/footer') %>
