<%- include('../partials/header') %>
<main>
    <div class="dashboard">
        <div class="side-view">
            <div class="side-view-left">
                <h1>Submitted Reviews</h1>
            </div>
            <div class="side-view-right">
                <p><a href="/dashboard" class="btn lowlight">Back to Dashboard</a></p>
            </div>
        </div>

        <% if (reviews && reviews.length > 0) { %>
            <ul class="moderation-reviews-list">
                <% reviews.forEach(review => { %>
                    <li class="card">
                        <div class="review-meta">
                            <strong>Vehicle:</strong>
                            <a href="/vehicles/<%= review.vehicle_id %>"><%= review.vehicle_year %> <%= review.vehicle_make %> <%= review.vehicle_model %></a>
                            <span class="moderation-meta-sep">|</span>
                            <strong>By:</strong> <%= review.user_name %>
                            <span class="moderation-meta-sep">|</span>
                            <span aria-label="Rating: <%= review.rating %> out of 5">
                                <% for (let i = 0; i < 5; i++) { %><%= i < review.rating ? '★' : '☆' %><% } %>
                            </span>
                            <span class="moderation-meta-sep">|</span>
                            <span><%= new Date(review.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                        </div>
                        <p class="review-body"><%= review.body %></p>
                        <div class="review-actions">
                            <form method="POST" action="/moderation/reviews/<%= review.id %>/approve">
                                <button type="submit" class="btn">Approve</button>
                            </form>
                            <form method="POST" action="/moderation/reviews/<%= review.id %>/reject" onsubmit="return confirm('Are you sure you want to delete this review? This cannot be undone.');">
                                <button type="submit" class="btn lowlight btn-danger">Reject &amp; Delete</button>
                            </form>
                        </div>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p class="no-reviews">No reviews awaiting approval.</p>
        <% } %>
    </div>
</main>
<%- include('../partials/footer') %>
