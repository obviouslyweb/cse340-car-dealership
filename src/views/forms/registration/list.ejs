<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>

            <div class="users-list">
                <% if (users && users.length > 0) { %>
                    <% users.forEach(listUser => { %>
                        <% 
                            // Calculate permissions for this user card
                            const currentUser = typeof isLoggedIn !== 'undefined' && isLoggedIn ? user : null;
                            const canEdit = currentUser && (currentUser.id === listUser.id || currentUser.roleName === 'admin');
                            const canDelete = currentUser && currentUser.roleName === 'admin' && currentUser.id !== listUser.id;
                        %>
                        <div class="user-card">
                        <div class="user-header">
                            <h3><%= listUser.name %></h3>
                            <span class="user-id">ID: <%= listUser.id %></span>
                        </div>

                        <div class="user-details">
                            <div class="detail-item">
                                <div class="label">Email</div>
                                <div class="value"><%= listUser.email %></div>
                            </div>

                            <% if (canEdit || canDelete) { %>
                                <div class="user-actions">
                                    <% if (canEdit) { %>
                                        <a href="/register/<%= listUser.id %>/edit">Edit</a>
                                    <% } %>
                                    <% if (canDelete) { %>
                                        <form method="POST" action="/register/<%= listUser.id %>/delete" class="form-inline">
                                            <button class="warning" type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="detail-item">
                                <div class="label">Registered</div>
                                <div class="value"><%= new Date(listUser.created_at).toLocaleDateString() %></div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p class="no-users">No users registered yet.</p>
                <% } %>
            </div>

</main>
<%- include('../../partials/footer') %>