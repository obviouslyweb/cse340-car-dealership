<%- include('partials/header') %>
<main>
    <section class="hero">
        <div class="hero-content">
            <h2 class="hero-title">Get There with Fuse</h2>
            <p class="hero-text">Whatever you're looking for, we can help you find it.</p>
            <a href="/vehicles" class="hero-cta btn">All Vehicles</a>
        </div>
    </section>

    <div class="side-view">
        <div class="side-view-left">
            <h2>Featured Vehicles</h2>
        </div>
        <div class="side-view-right">
            <p>Browse our featured vehicles and click on any to see full details.</p>
            <a href="/vehicles" class="btn">See All Vehicles</a>
        </div>
    </div>
    <div class="vehicle-list">
        <% if (featuredVehicles && featuredVehicles.length > 0) { %>
            <% featuredVehicles.forEach(vehicle => { %>

                <div class="vehicle-card">
                    <a href="/vehicles/<%= vehicle.id %>">
                        <img class="card-img" src="<%= vehicle.image_url || 'https://placehold.co/400x300/eee/999?text=No+Image' %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>">
                    </a>
                    <div class="vehicle-card-details">
                        <h3 class="vehicle-title">
                            <a href="/vehicles/<%= vehicle.id %>"><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></a>
                        </h3>
                        <div class="vehicle-meta side-view">
                            <div class="side-view-left">
                            <p><span class="vehicle-meta-focus">$<%= Number(vehicle.price).toLocaleString() %></span></p>
                            <p><% if (vehicle.mileage) { %><%= vehicle.mileage.toLocaleString() %> mi<% } %></p>
                            <p><span class="vehicle-meta-rating">★ <%= vehicle.average_rating != null ? Number(vehicle.average_rating).toFixed(1) : 'N/A' %></span></p>
                            </div>
                            <div class="side-view-right">
                                <% if (vehicle.stock > 0) { %>
                                    <p class="instock"><%= vehicle.stock %> remaining</p>
                                <% } else { %>
                                    <p class="nostock">Out of stock</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

            <% }); %>
        <% } else { %>
            <p>No featured vehicles at this time.</p>
        <% } %>
    </div>
    <h2>Why Choose Fuse?</h2>
    <p>Fuse Automobiles is the premiere digital car dealership, providing you with the wheels you need for a fraction of the cost.</p>
    <p>Founded in 2018, we pride ourselves on the quality and speed of our website, which you're on right now.</p>
</main>
<%- include('partials/footer') %>