<%- include('../partials/header') %>
<main>
    <div class="side-view">
        <div class="side-view-left">
            <h2>All Vehicles</h2>
        </div>
        <div class="side-view-right">
            <p>Filter by type</p>
            <a href="/vehicles<%= showUnavailable ? '?showUnavailable=1' : '' %>" class="btn sort-btn <%= !currentCategoryId ? 'active' : '' %>">All</a>

            <% if (categories && categories.length) { %>
                <% categories.forEach(category => { %>
                    <a href="/vehicles?categoryId=<%= category.id %><%= showUnavailable ? '&showUnavailable=1' : '' %>" class="btn sort-btn <%= currentCategoryId === category.id ? 'active' : '' %>">
                        <%= category.name %>
                    </a>
                <% }); %>
            <% } %>

            <% 
                const baseCategoryQuery = currentCategoryId ? `categoryId=${currentCategoryId}&` : '';
                const toggleShowUnavailable = showUnavailable ? '0' : '1';
            %>
            <a href="/vehicles?<%= baseCategoryQuery %>showUnavailable=<%= toggleShowUnavailable %>" class="btn unavailable-button <%= showUnavailable ? 'active' : '' %>">
                <%= showUnavailable ? 'Hide Unavailable' : 'Show Unavailable' %>
            </a>
        </div>
    </div>
    <div class="vehicle-list-buffer">
        <div class="vehicle-list">
            <% if (vehicles && vehicles.length > 0) { %>
                <% vehicles.forEach(vehicle => { %>

                    <div class="vehicle-card">
                        <a href="/vehicles/<%= vehicle.id %>">
                            <img class="card-img" src="<%= vehicle.image_url || 'https://placehold.co/400x300/eee/999?text=No+Image' %>" alt="<%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>">
                        </a>
                        <div class="vehicle-card-details">
                            <h3 class="vehicle-title">
                                <a href="/vehicles/<%= vehicle.id %>"><%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></a>
                            </h3>
                            <div class="vehicle-meta side-view">
                                <div class="side-view-left">
                                <p><span class="vehicle-meta-focus">$<%= Number(vehicle.price).toLocaleString() %></span></p>
                                <% if (vehicle.mileage) { %> - <%= vehicle.mileage.toLocaleString() %> mi<% } %></p>
                                </div>
                                <div class="side-view-right">
                                    <% if (vehicle.stock > 0) { %>
                                        <p class="instock"><%= vehicle.stock %> remaining</p>
                                    <% } else { %>
                                        <p class="nostock">Out of stock</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                <% }); %>
            <% } else { %>
                <p>No vehicles available at this time.</p>
            <% } %>

        </div>
    </div>
</main>
<%- include('../partials/footer') %>
